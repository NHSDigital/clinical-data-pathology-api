meta {
  name: Bundle-Invalid-Payload
  type: http
  seq: 2
}

post {
  url: http://localhost:5002/FHIR/R4/Bundle
  body: json
  auth: inherit
}

body:json {
  {
  "resourceType": "Bundle",
    "type": "document1",
    "entry": [
      {
        "fullUrl": "patient",
        "resource": {
          "resourceType": "Patient",
          "identifier": {
            "system": "https://fhir.nhs.uk/Id/nhs-number",
            "value": "nhs_number"
          }
        }
      }
    ]
  }
}

assert {
